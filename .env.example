POSTGRES_DB=cashlane
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_ISSUER=cashlane-api
JWT_AUDIENCE=cashlane-web
JWT_SIGNING_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=replace@example.com
SMTP_PASSWORD=replace-with-app-password
SMTP_FROM_EMAIL=replace@example.com
SMTP_FROM_NAME=Cashlane

DEMO_ENABLE=true
DEMO_EMAIL=demo@cashlane.app
DEMO_PASSWORD=Cashlane123
DEMO_DISPLAY_NAME=Cashlane Demo
